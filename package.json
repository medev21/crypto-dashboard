            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "devDependencies": {
        "eslint": "^8.7.0",
        "husky": "^7.0.0",
        "lint-staged": "^12.2.2",
        "prettier": "^2.5.1"
    },
    "lint-staged": {
        "src/**/*.{js,jsx,ts,tsx,json}": [
            "npm run pretty",
            "npm run lint"
        ],
        "src/**/*.{css,scss}": [
            "npm run pretty"
        ]
